{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "removebg",
  "compatibility_date": "2026-04-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist/frontend/browser"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "removebg.lastbench.dev/*",
      "zone_name": "lastbench.dev"
    }
  ]
}